{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "useDefineForClassFields": true,
    "strict": true,
    "jsx": "preserve",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "types": [
      "vite/client",
      "vitest/globals"
    ]
  },
  "include": [
    "webview/src/**/*.ts",
    "webview/src/**/*.vue",
    "tests/webview/**/*.ts"
  ]
}
